<node function_type="FIREWALL" name="edge_firewall">
    <configuration name="AutoConf">
        <firewall defaultAction="drop">
            <elements>
                <action>accept</action>
                <source>172.16.0.5</source>
                <destination>8.8.8.8</destination>
                <protocol>udp</protocol>
                <dest_port>53</dest_port>
            </elements>
        </firewall>
    </configuration>
</node>
